    "# ⚗️ Paper 3: Spill Containment Efficiency & Response Time ML Analysis\n",
    "## Niger Delta, Nigeria — Containment Efficiency Ratio (CER) + Response Time Index (RTI)\n",
    "\n",
    "**Journal target:** Stochastic Environmental Research and Risk Assessment (Springer)  \n",
    "**Dataset:** 335 confirmed oil spill incidents (NAOC & SPDC, 2016–2024)  \n",
    "**Methods:** XGBoost (classification + regression), SHAP, Temporal Trend Analysis, Chow Test  \n",
    "**Task:** Predict CER class + RTI; benchmark NAOC vs SPDC; pipeline vs flowline\n",
    "\n",
    "---\n",
    "> GitHub: [your-repo-link]  \n",
    "> Cite: [Your Name et al., Stoch Environ Res Risk Assess, 2024]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 0. Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from scipy import stats\n",
    "\n",
    "# ML\n",
    "from sklearn.model_selection import StratifiedKFold, KFold, train_test_split, cross_val_score\n",
    "from sklearn.preprocessing import RobustScaler, LabelEncoder\n",
    "from sklearn.ensemble import RandomForestClassifier, RandomForestRegressor, GradientBoostingClassifier\n",
    "from sklearn.ensemble import GradientBoostingRegressor\n",
    "from sklearn.linear_model import Ridge, LogisticRegression\n",
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "from sklearn.metrics import (roc_auc_score, accuracy_score, f1_score,\n",
    "                              mean_squared_error, mean_absolute_error, r2_score,\n",
    "                              classification_report, ConfusionMatrixDisplay, confusion_matrix)\n",
    "import xgboost as xgb\n",
    "import shap\n",
    "\n",
    "np.random.seed(42)\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "sns.set_palette('husl')\n",
    "\n",
    "print('✅ Packages loaded')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Data Loading & Outcome Variable Construction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('oils_data.csv', encoding='latin1')\n",
    "\n",
    "# Parse dates\n",
    "for col in ['Incident_d', 'Report_dat', 'Spill_stop']:\n",
    "    df[col] = pd.to_datetime(df[col], errors='coerce')\n",
    "\n",
    "df['year'] = df['Incident_d'].dt.year\n",
    "df['month'] = df['Incident_d'].dt.month\n",
    "df['quarter'] = df['Incident_d'].dt.to_period('Q')\n",
    "df['dry_season'] = df['month'].apply(lambda m: 1 if m in [11,12,1,2] else 0)\n",
    "\n",
    "# ── Outcome 1: CER (Containment Efficiency Ratio) ────────────────────────────\n",
    "df['CER'] = np.where(\n",
    "    (df['Estimated'] > 0) & (df['Qauntity_r'] >= 0),\n",
    "    (df['Qauntity_r'] / df['Estimated']) * 100,\n",
    "    np.nan\n",
    ")\n",
    "df['CER'] = df['CER'].clip(0, 100)  # Cap at 100%\n",
    "\n",
    "# ── Outcome 2: RTI (Response Time Index) ─────────────────────────────────────\n",
    "df['RTI'] = (df['Spill_stop'] - df['Incident_d']).dt.days.clip(lower=0)\n",
    "\n",
    "# Report lag\n",
    "df['report_lag'] = (df['Report_dat'] - df['Incident_d']).dt.days.clip(lower=0)\n",
    "df['report_lag'].fillna(df['report_lag'].median(), inplace=True)\n",
    "\n",
    "# Classify CER into Low/Medium/High\n",
    "df['CER_class'] = pd.cut(df['CER'], bins=[-0.1, 33, 67, 100.1],\n",
    "                          labels=['Low', 'Medium', 'High'])\n",
    "\n",
    "df_cer = df[df['CER'].notna() & df['Estimated'] > 0].copy()  # n=278\n",
    "df_rti = df[df['RTI'].notna()].copy()  # n=238\n",
    "\n",
    "print(f'CER dataset: {len(df_cer)} incidents')\n",
    "print(f'RTI dataset: {len(df_rti)} incidents')\n",
    "print(f'\\nCER stats: mean={df_cer[\"CER\"].mean():.1f}%, median={df_cer[\"CER\"].median():.1f}%')\n",
    "print(f'RTI stats: mean={df_rti[\"RTI\"].mean():.1f} days, median={df_rti[\"RTI\"].median():.1f} days')\n",
    "print()\n",
    "print('CER class distribution:')\n",
    "print(df_cer['CER_class'].value_counts())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
