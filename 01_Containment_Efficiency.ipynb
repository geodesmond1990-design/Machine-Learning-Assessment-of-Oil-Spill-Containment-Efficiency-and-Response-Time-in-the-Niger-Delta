   "source": [
    "# ── Temporal CER and RTI trends ────────────────────────────────────────────────\n",
    "# Quarterly CER\n",
    "df_cer['quarter'] = pd.to_datetime(df_cer['Incident_d']).dt.to_period('Q')\n",
    "quarterly_cer = df_cer.groupby('quarter')['CER'].agg(['mean','sem']).reset_index()\n",
    "quarterly_cer['quarter_str'] = quarterly_cer['quarter'].astype(str)\n",
    "\n",
    "df_rti['quarter'] = pd.to_datetime(df_rti['Incident_d']).dt.to_period('Q')\n",
    "quarterly_rti = df_rti.groupby('quarter')['RTI'].agg(['mean','sem']).reset_index()\n",
    "quarterly_rti['quarter_str'] = quarterly_rti['quarter'].astype(str)\n",
    "\n",
    "fig, axes = plt.subplots(2, 1, figsize=(14, 10))\n",
    "fig.suptitle('Temporal Performance Trends — CER and RTI (2016–2024)', fontsize=13, fontweight='bold')\n",
    "\n",
    "# CER trend\n",
    "x_cer = range(len(quarterly_cer))\n",
    "axes[0].plot(x_cer, quarterly_cer['mean'], 'o-', color='#27ae60', lw=2, markersize=6)\n",
    "axes[0].fill_between(x_cer,\n",
    "                      quarterly_cer['mean'] - 1.96*quarterly_cer['sem'],\n",
    "                      quarterly_cer['mean'] + 1.96*quarterly_cer['sem'],\n",
    "                      alpha=0.2, color='#27ae60')\n",
    "axes[0].set_title('Quarterly Mean CER (%)')\n",
    "axes[0].set_ylabel('Mean CER (%)')\n",
    "axes[0].set_xticks(range(0, len(quarterly_cer), 2))\n",
    "axes[0].set_xticklabels(quarterly_cer['quarter_str'].iloc[::2], rotation=45, fontsize=8)\n",
    "\n",
    "# RTI trend\n",
    "x_rti = range(len(quarterly_rti))\n",
    "axes[1].plot(x_rti, quarterly_rti['mean'], 'o-', color='#e74c3c', lw=2, markersize=6)\n",
    "axes[1].fill_between(x_rti,\n",
    "                      quarterly_rti['mean'] - 1.96*quarterly_rti['sem'],\n",
    "                      quarterly_rti['mean'] + 1.96*quarterly_rti['sem'],\n",
    "                      alpha=0.2, color='#e74c3c')\n",
    "axes[1].set_title('Quarterly Mean RTI (days)')\n",
    "axes[1].set_ylabel('Mean RTI (days)')\n",
    "axes[1].set_xticks(range(0, len(quarterly_rti), 2))\n",
    "axes[1].set_xticklabels(quarterly_rti['quarter_str'].iloc[::2], rotation=45, fontsize=8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('fig4_temporal_trends.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# Simple linear trend test\n",
    "from scipy.stats import linregress\n",
    "slope_cer, intercept_cer, r_cer, p_cer, se_cer = linregress(range(len(quarterly_cer)), quarterly_cer['mean'])\n",
    "slope_rti, intercept_rti, r_rti, p_rti, se_rti = linregress(range(len(quarterly_rti)), quarterly_rti['mean'])\n",
    "\n",
    "print(f'CER temporal trend: slope={slope_cer:.3f}%/quarter, p={p_cer:.4f} ({\"Significant\" if p_cer<0.05 else \"Not significant\"})')\n",
    "print(f'RTI temporal trend: slope={slope_rti:.3f} days/quarter, p={p_rti:.4f} ({\"Significant\" if p_rti<0.05 else \"Not significant\"})')"
