  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Feature Engineering for ML"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_features(df_in):\n",
    "    \"\"\"Build feature matrix for CER/RTI prediction.\"\"\"\n",
    "    X = pd.DataFrame()\n",
    "    \n",
    "    # Volume\n",
    "    X['log_volume'] = np.log1p(df_in['Estimated'].fillna(0))\n",
    "    \n",
    "    # Facility type\n",
    "    X['facility_enc'] = df_in['Type_of_fa'].str.strip().map(\n",
    "        {'pl': 3, 'fl': 2, 'mf': 1, 'wh': 1}).fillna(1)\n",
    "    X['is_flowline'] = (df_in['Type_of_fa'].str.strip() == 'fl').astype(int)\n",
    "    \n",
    "    # Company\n",
    "    X['company_naoc'] = (df_in['Company'] == 'NAOC').astype(int)\n",
    "    \n",
    "    # Contamination\n",
    "    cont_map = {'cr': 3, 'co': 2, 'no': 1}\n",
    "    X['contam_sev'] = df_in['Contaminan'].str.strip().map(cont_map).fillna(0)\n",
    "    X['is_crude'] = (df_in['Contaminan'].str.strip() == 'cr').astype(int)\n",
    "    \n",
    "    # Affected surface\n",
    "    def eco_score(x):\n",
    "        x = str(x).lower()\n",
    "        if 'sw' in x or 'ss' in x: return 3\n",
    "        if 'iw' in x: return 2\n",
    "        return 1\n",
    "    X['eco_vuln'] = df_in['Spill_area'].apply(eco_score)\n",
    "    X['is_water_swamp'] = (X['eco_vuln'] >= 3).astype(int)\n",
    "    \n",
    "    # Temporal\n",
    "    X['month'] = pd.to_datetime(df_in['Incident_d']).dt.month.fillna(6)\n",
    "    X['month_sin'] = np.sin(2 * np.pi * X['month'] / 12)\n",
    "    X['month_cos'] = np.cos(2 * np.pi * X['month'] / 12)\n",
    "    X['dry_season'] = X['month'].apply(lambda m: 1 if m in [11,12,1,2] else 0)\n",
    "    X['year'] = pd.to_datetime(df_in['Incident_d']).dt.year.fillna(2020)\n",
    "    X.drop('month', axis=1, inplace=True)\n",
    "    \n",
    "    # Report lag\n",
    "    X['report_lag'] = df_in['report_lag'].fillna(df_in['report_lag'].median())\n",
    "    X['log_report_lag'] = np.log1p(X['report_lag'])\n",
    "    \n",
    "    # LGA encoding\n",
    "    lga_mean = df_in.groupby('LGA')['CER'].mean() if 'CER' in df_in.columns else None\n",
    "    if lga_mean is not None:\n",
    "        X['lga_mean_cer'] = df_in['LGA'].map(lga_mean).fillna(df_in.get('CER', pd.Series([50]*len(df_in))).mean())\n",
    "    \n",
    "    # Spatial\n",
    "    X['latitude'] = df_in['Latitude'].fillna(df_in['Latitude'].mean())\n",
    "    X['longitude'] = df_in['Longitude'].fillna(df_in['Longitude'].mean())\n",
    "    \n",
    "    return X.fillna(X.median())\n",
    "\n",
    "X_cer = build_features(df_cer)\n",
    "y_cer_class = df_cer['CER_class'].map({'Low': 0, 'Medium': 1, 'High': 2})\n",
    "y_cer_reg = df_cer['CER']\n",
    "\n",
    "X_rti = build_features(df_rti)\n",
    "y_rti = np.log1p(df_rti['RTI'])  # log-transform for regression\n",
    "\n",
    "print(f'CER feature matrix: {X_cer.shape}')\n",
    "print(f'RTI feature matrix: {X_rti.shape}')\n",
    "print(f'Features: {X_cer.columns.tolist()}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. CER Classification Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CER Classification ────────────────────────────────────────────────────────\n",
    "scaler_cer = RobustScaler()\n",
    "X_cer_scaled = scaler_cer.fit_transform(X_cer)\n",
    "\n",
    "clf_models = {\n",
    "    'KNN': KNeighborsClassifier(n_neighbors=7),\n",
    "    'Random Forest': RandomForestClassifier(n_estimators=300, random_state=42, n_jobs=-1),\n",
    "    'Gradient Boosting': GradientBoostingClassifier(n_estimators=300, learning_rate=0.05, random_state=42),\n",
    "    'XGBoost': xgb.XGBClassifier(n_estimators=500, learning_rate=0.05, max_depth=5,\n",
    "                                   subsample=0.8, random_state=42, verbosity=0, eval_metric='mlogloss')\n",
    "}\n",
    "\n",
    "cv_cer = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "results_cer = {}\n",
    "\n",
    "for name, model in clf_models.items():\n",
    "    print(f'Training {name} (CER classifier)...')\n",
    "    aucs, accs, f1s = [], [], []\n",
    "    \n",
    "    for tr_idx, te_idx in cv_cer.split(X_cer_scaled, y_cer_class):\n",
    "        X_tr, X_te = X_cer_scaled[tr_idx], X_cer_scaled[te_idx]\n",
    "        y_tr, y_te = y_cer_class.iloc[tr_idx], y_cer_class.iloc[te_idx]\n",
    "        \n",
    "        model.fit(X_tr, y_tr)\n",
    "        y_pred = model.predict(X_te)\n",
    "        y_proba = model.predict_proba(X_te)\n",
    "        \n",
    "        aucs.append(roc_auc_score(y_te, y_proba, multi_class='ovr'))\n",
    "        accs.append(accuracy_score(y_te, y_pred))\n",
    "        f1s.append(f1_score(y_te, y_pred, average='weighted'))\n",
    "    \n",
    "    results_cer[name] = {'AUC': np.mean(aucs), 'Accuracy': np.mean(accs), 'F1': np.mean(f1s)}\n",
    "    print(f'  AUC={results_cer[name][\"AUC\"]:.4f}  Acc={results_cer[name][\"Accuracy\"]:.4f}')\n",
    "\n",
    "results_cer_df = pd.DataFrame(results_cer).T.sort_values('AUC', ascending=False)\n",
    "print('\\n=== CER CLASSIFICATION RESULTS ===')\n",
    "print(results_cer_df.round(4))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. RTI Regression Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── RTI Regression ────────────────────────────────────────────────────────────\n",
    "scaler_rti = RobustScaler()\n",
    "X_rti_scaled = scaler_rti.fit_transform(X_rti)\n",
    "\n",
    "reg_models = {\n",
    "    'Ridge Regression': Ridge(alpha=1.0),\n",
    "    'Random Forest': RandomForestRegressor(n_estimators=300, random_state=42, n_jobs=-1),\n",
    "    'Gradient Boosting': GradientBoostingRegressor(n_estimators=300, learning_rate=0.05, random_state=42),\n",
    "    'XGBoost': xgb.XGBRegressor(n_estimators=500, learning_rate=0.05, max_depth=5,\n",
    "                                  subsample=0.8, random_state=42, verbosity=0)\n",
    "}\n",
    "\n",
    "cv_rti = KFold(n_splits=5, shuffle=True, random_state=42)\n",
    "results_rti = {}\n",
    "\n",
    "for name, model in reg_models.items():\n",
    "    print(f'Training {name} (RTI regressor)...')\n",
    "    rmses, maes, r2s = [], [], []\n",
    "    \n",
    "    for tr_idx, te_idx in cv_rti.split(X_rti_scaled):\n",
    "        X_tr, X_te = X_rti_scaled[tr_idx], X_rti_scaled[te_idx]\n",
    "        y_tr, y_te = y_rti.iloc[tr_idx], y_rti.iloc[te_idx]\n",
    "        \n",
    "        model.fit(X_tr, y_tr)\n",
    "        y_pred = model.predict(X_te)\n",
    "        \n",
    "        rmses.append(np.sqrt(mean_squared_error(y_te, y_pred)))\n",
    "        maes.append(mean_absolute_error(y_te, y_pred))\n",
    "        r2s.append(r2_score(y_te, y_pred))\n",
    "    \n",
    "    results_rti[name] = {'RMSE': np.mean(rmses), 'MAE': np.mean(maes), 'R2': np.mean(r2s)}\n",
    "    print(f'  RMSE={results_rti[name][\"RMSE\"]:.4f}  MAE={results_rti[name][\"MAE\"]:.4f}  R2={results_rti[name][\"R2\"]:.4f}')\n",
    "\n",
    "results_rti_df = pd.DataFrame(results_rti).T.sort_values('R2', ascending=False)\n",
    "print('\\n=== RTI REGRESSION RESULTS ===')\n",
    "print(results_rti_df.round(4))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. SHAP Analysis — Best XGBoost Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Train Final Models ─────────────────────────────────────────────────────────\n",
    "X_c_tr, X_c_te, y_c_tr, y_c_te = train_test_split(X_cer_scaled, y_cer_class, test_size=0.2,\n",
    "                                                     stratify=y_cer_class, random_state=42)\n",
    "X_r_tr, X_r_te, y_r_tr, y_r_te = train_test_split(X_rti_scaled, y_rti, test_size=0.2, random_state=42)\n",
    "\n",
    "xgb_clf = xgb.XGBClassifier(n_estimators=500, learning_rate=0.05, max_depth=5,\n",
    "                               subsample=0.8, random_state=42, verbosity=0, eval_metric='mlogloss')\n",
    "xgb_reg = xgb.XGBRegressor(n_estimators=500, learning_rate=0.05, max_depth=5,\n",
    "                               subsample=0.8, random_state=42, verbosity=0)\n",
    "\n",
    "xgb_clf.fit(X_c_tr, y_c_tr)\n",
    "xgb_reg.fit(X_r_tr, y_r_tr)\n",
    "\n",
    "y_c_pred = xgb_clf.predict(X_c_te)\n",
    "y_c_proba = xgb_clf.predict_proba(X_c_te)\n",
    "y_r_pred = xgb_reg.predict(X_r_te)\n",
    "\n",
    "print('=== CER CLASSIFIER REPORT ===')\n",
    "print(classification_report(y_c_te, y_c_pred, target_names=['Low','Medium','High']))\n",
    "print(f'AUC: {roc_auc_score(y_c_te, y_c_proba, multi_class=\"ovr\"):.4f}')\n",
    "print()\n",
    "print('=== RTI REGRESSOR REPORT ===')\n",
    "print(f'RMSE: {np.sqrt(mean_squared_error(y_r_te, y_r_pred)):.4f}')\n",
    "print(f'MAE: {mean_absolute_error(y_r_te, y_r_pred):.4f}')\n",
    "print(f'R²: {r2_score(y_r_te, y_r_pred):.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── SHAP ──────────────────────────────────────────────────────────────────────\n",
    "feature_names = X_cer.columns.tolist()\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 7))\n",
    "fig.suptitle('SHAP Feature Importance — CER & RTI Models', fontsize=13, fontweight='bold')\n",
    "\n",
    "# CER classifier SHAP\n",
    "explainer_clf = shap.TreeExplainer(xgb_clf)\n",
    "shap_clf = explainer_clf.shap_values(X_c_te)\n",
    "# Mean across classes\n",
    "shap_clf_mean = np.mean([np.abs(shap_clf[i]).mean(axis=0) for i in range(3)], axis=0)\n",
    "shap_cer_df = pd.DataFrame({'feature': feature_names, 'shap': shap_clf_mean}).sort_values('shap', ascending=False)\n",
    "\n",
    "axes[0].barh(shap_cer_df['feature'][:10][::-1], shap_cer_df['shap'][:10][::-1], color='#27ae60')\n",
    "axes[0].set_title('CER Classifier — Feature Importance')\n",
    "axes[0].set_xlabel('Mean |SHAP|')\n",
    "\n",
    "# RTI regressor SHAP\n",
    "explainer_reg = shap.TreeExplainer(xgb_reg)\n",
    "shap_reg = explainer_reg.shap_values(X_r_te)\n",
    "shap_reg_mean = np.abs(shap_reg).mean(axis=0)\n",
    "shap_rti_df = pd.DataFrame({'feature': feature_names, 'shap': shap_reg_mean}).sort_values('shap', ascending=False)\n",
    "\n",
    "axes[1].barh(shap_rti_df['feature'][:10][::-1], shap_rti_df['shap'][:10][::-1], color='#e67e22')\n",
    "axes[1].set_title('RTI Regressor — Feature Importance')\n",
    "axes[1].set_xlabel('Mean |SHAP|')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('fig2_shap_cer_rti.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print('\\nTop CER predictors:')\n",
    "print(shap_cer_df.head(7).to_string(index=False))\n",
    "print('\\nTop RTI predictors:')\n",
    "print(shap_rti_df.head(7).to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Operator & Facility Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Statistical Comparisons ────────────────────────────────────────────────────\n",
    "naoc_cer = df_cer[df_cer['Company']=='NAOC']['CER'].dropna()\n",
    "spdc_cer = df_cer[df_cer['Company']=='SPDC']['CER'].dropna()\n",
    "u_stat, p_val = stats.mannwhitneyu(naoc_cer, spdc_cer, alternative='two-sided')\n",
    "cohens_d = (naoc_cer.mean() - spdc_cer.mean()) / np.sqrt((naoc_cer.std()**2 + spdc_cer.std()**2) / 2)\n",
    "\n",
    "print('=== OPERATOR COMPARISON (NAOC vs SPDC) ===')\n",
    "print(f'NAOC: n={len(naoc_cer)}, mean CER={naoc_cer.mean():.1f}%, SD={naoc_cer.std():.1f}%')\n",
    "print(f'SPDC: n={len(spdc_cer)}, mean CER={spdc_cer.mean():.1f}%, SD={spdc_cer.std():.1f}%')\n",
    "print(f'Mann-Whitney U={u_stat:.1f}, p={p_val:.4f}')\n",
    "print(f\"Cohen's d = {cohens_d:.3f} (effect size: {'small' if abs(cohens_d)<0.5 else 'medium'})\")\n",
    "\n",
    "# Facility comparison\n",
    "pl_cer = df_cer[df_cer['Type_of_fa']=='pl']['CER'].dropna()\n",
    "fl_cer = df_cer[df_cer['Type_of_fa']=='fl']['CER'].dropna()\n",
    "u_stat_fa, p_val_fa = stats.mannwhitneyu(pl_cer, fl_cer, alternative='two-sided')\n",
    "cohens_d_fa = (pl_cer.mean() - fl_cer.mean()) / np.sqrt((pl_cer.std()**2 + fl_cer.std()**2) / 2)\n",
    "\n",
    "print()\n",
    "print('=== FACILITY COMPARISON (Pipeline vs Flowline) ===')\n",
    "print(f'Pipeline: n={len(pl_cer)}, mean CER={pl_cer.mean():.1f}%, SD={pl_cer.std():.1f}%')\n",
    "print(f'Flowline: n={len(fl_cer)}, mean CER={fl_cer.mean():.1f}%, SD={fl_cer.std():.1f}%')\n",
    "print(f'Mann-Whitney U={u_stat_fa:.1f}, p={p_val_fa:.4f}')\n",
    "print(f\"Cohen's d = {cohens_d_fa:.3f} ({'statistically significant' if p_val_fa < 0.05 else 'not significant'})\")"
   ]
  },
